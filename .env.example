# Web service
PORT=3000
NODE_ENV=production
DATA_DIR=/app/data
DATABASE_PATH=/app/data/liteoj.db
JWT_SECRET=replace-this-with-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-this-admin-password

# Judge worker
JUDGE_TOKEN=replace-this-judge-token
# Same-server production uses a host judge worker. Keep BACKEND_URL loopback.
BACKEND_URL=http://127.0.0.1:3000
JUDGE_POLL_INTERVAL_MS=2000
JUDGE_MAX_OUTPUT_BYTES=1048576
# go-judge: recommended production executor. The worker sends compile/run
# requests to a dedicated go-judge service instead of starting per-run Docker
# containers by itself.
# local: legacy executor using JUDGE_SANDBOX below, useful for simple dev only.
JUDGE_EXECUTOR=go-judge
GO_JUDGE_URL=http://127.0.0.1:5050
GO_JUDGE_PORT=5050
GO_JUDGE_BASE_IMAGE=criyle/go-judge:latest
# Legacy local executor sandbox. Used only when JUDGE_EXECUTOR=local.
JUDGE_SANDBOX=docker
JUDGE_SANDBOX_IMAGE=liteoj:latest
JUDGE_SANDBOX_CPUS=1
JUDGE_PROCESS_LIMIT=64
JUDGE_FILE_LIMIT_KB=65536
TESTDATA_ZIP_LIMIT=50
TESTDATA_UNZIPPED_LIMIT=200
LOGIN_RATE_LIMIT=20
REGISTER_RATE_LIMIT=10
NPM_REGISTRY=https://registry.npmmirror.com
DOCKER_BUILD_APT_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/debian
DOCKER_BUILD_APT_SECURITY_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/debian-security
DOCKER_BUILD_NETWORK=host
LITEOJ_AUTO_PORT=1
LITEOJ_PORT_SCAN_END=3099
LITEOJ_GO_JUDGE_PORT_SCAN_END=5099
LITEOJ_APT_MIRROR=1

# Cookie security
# auto: add Secure only when the current request is HTTPS. This avoids browser
# warnings on http://localhost:3000 while keeping HTTPS deployments secure.
# Use COOKIE_SECURE=1 to force Secure behind a strict HTTPS deployment, or
# COOKIE_SECURE=0 only for temporary plain-HTTP testing.
COOKIE_SECURE=auto
