# Web service
PORT=3000
NODE_ENV=production
DATA_DIR=/app/data
DATABASE_PATH=/app/data/liteoj.db
JWT_SECRET=replace-this-with-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-this-admin-password

# Judge worker
JUDGE_TOKEN=replace-this-judge-token
# Same-server production uses a host judge worker. Keep BACKEND_URL loopback.
BACKEND_URL=http://127.0.0.1:3000
JUDGE_POLL_INTERVAL_MS=2000
JUDGE_MAX_OUTPUT_BYTES=1048576
# docker: run each compile/run in a no-network Docker container. This is the
# recommended same-server public deployment mode used by ./liteoj.sh.
# host: lightweight local limits, only for development/trusted LAN use.
JUDGE_SANDBOX=docker
JUDGE_SANDBOX_IMAGE=liteoj:latest
JUDGE_SANDBOX_CPUS=1
JUDGE_PROCESS_LIMIT=64
JUDGE_FILE_LIMIT_KB=65536
TESTDATA_ZIP_LIMIT=50
TESTDATA_UNZIPPED_LIMIT=200
LOGIN_RATE_LIMIT=20
REGISTER_RATE_LIMIT=10

# Cookie security
# auto: add Secure only when the current request is HTTPS. This avoids browser
# warnings on http://localhost:3000 while keeping HTTPS deployments secure.
# Use COOKIE_SECURE=1 to force Secure behind a strict HTTPS deployment, or
# COOKIE_SECURE=0 only for temporary plain-HTTP testing.
COOKIE_SECURE=auto
